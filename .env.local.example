# Supabase
NEXT_PUBLIC_SUPABASE_URL=https://vnexjqzdunijnfsgptyo.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-key-here
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key-here

# NREL PVWatts API (free: https://developer.nrel.gov/signup/)
NREL_API_KEY=DEMO_KEY

# Resend (email alerts, free tier: https://resend.com)
RESEND_API_KEY=your-resend-key-here

# SolarEdge (used for testing only; users provide their own)
SOLAREDGE_TEST_API_KEY=your-test-key
SOLAREDGE_TEST_SITE_ID=your-test-site-id

# Credential encryption (generate with: node -e "console.log(require('crypto').randomBytes(32).toString('hex'))")
CREDENTIAL_ENCRYPTION_KEY=your-64-char-hex-key-here

# Enphase OAuth (register at https://developer-v4.enphase.com/signup)
ENPHASE_API_KEY=your-enphase-api-key
ENPHASE_CLIENT_ID=your-enphase-client-id
ENPHASE_CLIENT_SECRET=your-enphase-client-secret
NEXT_PUBLIC_ENPHASE_REDIRECT_URI=https://www.getsolardoctor.com/api/enphase/callback
